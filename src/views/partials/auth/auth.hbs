<div class='modal fade' id='authModal' tabindex='-1'>
    <div class='modal-dialog modal-dialog-centered'>
        <div class='modal-content'>

            <!-- TABS -->
            <div class='modal-header pb-0 border-0'>
                <ul class='nav nav-tabs w-100'>
                    <li class='nav-item w-50 text-center'>
                        <button
                            class='nav-link {{#if (eq activeTab "login")}}active{{/if}} w-100'
                            data-bs-toggle='tab'
                            data-bs-target='#signInTab'
                            type='button'
                        >
                            Đăng Nhập
                        </button>
                    </li>
                    <li class='nav-item w-50 text-center'>
                        <button
                            class='nav-link {{#if (eq activeTab "register")}}active{{/if}} w-100'
                            data-bs-toggle='tab'
                            data-bs-target='#signUpTab'
                            type='button'
                        >
                            Đăng Kí
                        </button>
                    </li>
                </ul>

                <button
                    type='button'
                    class='btn-close position-absolute end-0 me-3 mt-2'
                    data-bs-dismiss='modal'
                >
                </button>
            </div>

            <!-- BODY -->
            <div class='modal-body pt-4'>
                <div class='tab-content'>

                    <!-- ===== SIGN IN ===== -->
                    <div class='tab-pane fade {{#if (ne activeTab "register")}}show active{{/if}}' id='signInTab'>
                        <h5 class='mb-4'>Đăng Nhập</h5>

                        {{#if loginError}}
                            <div class='alert alert-danger alert-dismissible fade show' role='alert'>
                                <i class='fa-solid fa-circle-exclamation me-2'></i>
                                {{loginError}}
                                <button type='button' class='btn-close' data-bs-dismiss='alert'></button>
                            </div>
                        {{/if}}

                        <form method='POST' action='/auth/login'>

                            <div class='mb-3'>
                                <label class='form-label'>Tên người dùng</label>
                                <input
                                    name='username'
                                    class='form-control'
                                    placeholder='Username'
                                />
                            </div>

                            <div class='mb-4'>
                                <label class='form-label'>Mật khẩu</label>
                                <input
                                    type='password'
                                    name='password'
                                    class='form-control login-password'
                                    placeholder='******************'
                                />
                                <small class='text-danger password-error' style='display: none;'>
                                    Mật khẩu phải có ít nhất 8 ký tự
                                </small>
                            </div>

                            <div
                                class='d-flex justify-content-between align-items-center'
                            >
                                <button class='btn btn-primary px-4'>
                                    Đăng Nhập
                                </button>

                                <a href='#' class='small'>
                                    Quên mật khẩu ?
                                </a>
                            </div>

                        </form>
                    </div>

                    <!-- ===== SIGN UP ===== -->
                    <div class='tab-pane fade {{#if (eq activeTab "register")}}show active{{/if}}' id='signUpTab'>
                        <h5 class='mb-4'>Đăng Kí</h5>

                        {{#if registerSuccess}}
                            <div class='alert alert-success alert-dismissible fade show' role='alert'>
                                <i class='fa-solid fa-circle-check me-2'></i>
                                {{registerSuccess}}
                                <button type='button' class='btn-close' data-bs-dismiss='alert'></button>
                            </div>
                        {{/if}}

                        {{#if registerError}}
                            <div class='alert alert-danger alert-dismissible fade show' role='alert'>
                                <i class='fa-solid fa-circle-exclamation me-2'></i>
                                {{registerError}}
                                <button type='button' class='btn-close' data-bs-dismiss='alert'></button>
                            </div>
                        {{/if}}

                        <form method='POST' action='/auth/register'>

                            <div class='mb-3'>
                                <label class='form-label'>Tên người dùng</label>
                                <input
                                    name='username'
                                    class='form-control'
                                    placeholder='Username'
                                />
                            </div>

                            <!-- PHONE + FLAG (CHUẨN YÊU CẦU) -->
                            <div class='mb-3'>
                                <label class='form-label'>Số điện thoại</label>
                                <div class='input-group'>
                                    <span class='input-group-text bg-white'>
                                        <img
                                            src='/img/flagvn.png'
                                            alt='VN'
                                            width='20'
                                            height='14'
                                            style='margin-right:6px'
                                        />
                                        +84
                                    </span>
                                    <input
                                        name='phone'
                                        class='form-control'
                                        placeholder='Số điện thoại'
                                    />
                                </div>
                            </div>

                            <div class='mb-3'>
                                <label class='form-label'>Email</label>
                                <input
                                    name='email'
                                    class='form-control'
                                    placeholder='Email address'
                                />
                            </div>

                            <div class='mb-4'>
                                <label class='form-label'>Mật khẩu </label>
                                <input
                                    type='password'
                                    name='password'
                                    class='form-control register-password'
                                    placeholder='******************'
                                />
                                <small class='text-danger password-error' style='display: none;'>
                                    Mật khẩu phải có ít nhất 8 ký tự
                                </small>
                            </div>

                            <button class='btn btn-primary w-100'>
                                Đăng Kí
                            </button>

                        </form>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>

<script>
    // Auto-open modal khi có lỗi hoặc thông báo
    document.addEventListener('DOMContentLoaded', function() {
        {{#if showAuthModal}}
            const authModal = new bootstrap.Modal(document.getElementById('authModal'));
            authModal.show();
        {{/if}}

        // Password validation - Login form
        const loginPassword = document.querySelector('.login-password');
        if (loginPassword) {
            loginPassword.addEventListener('input', function() {
                const errorMsg = this.parentElement.querySelector('.password-error');
                if (this.value.length < 8) {
                    errorMsg.style.display = 'block';
                    this.classList.add('is-invalid');
                    this.classList.remove('is-valid');
                } else {
                    errorMsg.style.display = 'none';
                    this.classList.remove('is-invalid');
                    this.classList.add('is-valid');
                }
            });
        }

        // Password validation - Register form
        const registerPassword = document.querySelector('.register-password');
        if (registerPassword) {
            registerPassword.addEventListener('input', function() {
                const errorMsg = this.parentElement.querySelector('.password-error');
                if (this.value.length < 8) {
                    errorMsg.style.display = 'block';
                    this.classList.add('is-invalid');
                    this.classList.remove('is-valid');
                } else {
                    errorMsg.style.display = 'none';
                    this.classList.remove('is-invalid');
                    this.classList.add('is-valid');
                }
            });
        }
    });
</script>