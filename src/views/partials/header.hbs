<nav class='navbar navbar-expand-lg bg-white'>
    <div class='container-fluid d-flex align-items-center'>

        <a class='navbar-brand' href='#'>
            <img src='/img/logo.jpg' alt='Logo' height='60' width="60" />
        </a>

        <div class='flex-grow-1 d-flex justify-content-center'>
            <form class='d-flex align-items-center' role='search' method='GET' action='/search'>
                <div class='input-group me-3'>

                    <input
                        type='search'
                        class='form-control'
                        placeholder='Tìm kiếm sản phẩm...'
                        aria-label='Search'
                        name='q'
                        required
                    />

                    <button class='btn btn-dark' type='submit'>
                        <i class='fa-solid fa-magnifying-glass'></i>
                    </button>

                </div>
            </form>
        </div>

        <div class='icon dropdown'>
                <a
                    href='#'
                    class='text-dark btn btn-secondary dropdown-toggle bg-white border-0'
                >
                    <i class='fa-regular fa-user fs-4'></i>
                </a>
                <ul class='dropdown-menu dropdown-menu-end'>
                    <li><a class='dropdown-item' href='/cart'>Giỏ hàng</a></li>
                    {{#if user}}
                        <span class='dropdown-item'>Xin chào
                            {{user.username}}</span>
                        <a
                            class='dropdown-item text-danger'
                            href='/auth/logout'
                        >Logout</a>
                    {{else}}
                        <a
                            class='dropdown-item'
                            data-bs-toggle='modal'
                            data-bs-target='#authModal'
                        >
                            Đăng nhập / Đăng ký
                        </a>
                    {{/if}}

                </ul>
            </div>
    </div>
</nav>